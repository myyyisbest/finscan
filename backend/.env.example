# finscan 后端环境变量示例。复制为 .env 后按需修改。

# ===== 应用 =====
DEBUG=true
LOG_LEVEL=INFO

# ===== 数据库 =====
# 开发默认 SQLite; 生产切 MariaDB:
# DATABASE_URL=mysql+pymysql://user:pwd@127.0.0.1:3306/finscan?charset=utf8mb4
DATABASE_URL=sqlite:///./data/finscan.db

# ===== JWT =====
SECRET_KEY=finscan-dev-secret-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===== 采集 =====
COLLECT_SCOPE=sample
COLLECT_SLEEP_MIN=1.0
COLLECT_SLEEP_MAX=3.0
COLLECT_RETRY=3

# ===== AI (DeepSeek) =====
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
